# memgar.com production environment
# Copy to .env at the repo root and fill in real values.
# DO NOT commit .env — it contains secrets.

# ── API authentication ──────────────────────────────────────────────────────
# Comma-separated list of API keys (any client must send X-API-Key header).
# Generate with:  python -c "import secrets; print('sk-memgar-' + secrets.token_urlsafe(32))"
MEMGAR_API_KEYS=sk-memgar-CHANGE-ME-CHANGE-ME-CHANGE-ME

# ── Grafana ─────────────────────────────────────────────────────────────────
# Admin password for grafana.memgar.com (required, no default)
GRAFANA_PASSWORD=CHANGE-ME-strong-password

# Caddy basic-auth hash for metrics.memgar.com (extra protection in front of Grafana)
# Generate with:  docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'your-password'
GRAFANA_BASIC_AUTH_HASH=$2a$14$REPLACE-WITH-OUTPUT-OF-CADDY-HASH-PASSWORD
